<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Introducing Eventwise - Financial Clarity for Every Event</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #242450; --navy-deep: #171740; --blue: #5777AB;
  --purple: #8403C5; --purple-light: #A855F7; --teal: #1D9E75;
  --white: #ffffff; --off-white: #F6F6FB; --grey: #E8E8F0;
  --grey-mid: #9999BB; --grey-dark: #555580; --font: 'DM Sans', sans-serif;
}
html { scroll-behavior: smooth; }
body { font-family: var(--font); background: var(--white); color: var(--navy); overflow-x: hidden; -webkit-font-smoothing: antialiased; }

/* PROGRESS BAR */
#progress-bar {
  position: fixed; top: 0; left: 0; height: 3px; width: 0%;
  background: linear-gradient(90deg, var(--teal), var(--purple));
  z-index: 9999; transition: width 0.1s linear;
  border-radius: 0 2px 2px 0;
}

/* SCROLL ANIMATIONS */
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: 0.08s; }
.reveal-delay-2 { transition-delay: 0.16s; }
.reveal-delay-3 { transition-delay: 0.24s; }
.reveal-delay-4 { transition-delay: 0.32s; }
.reveal-delay-5 { transition-delay: 0.40s; }

/* HERO */
.hero {
  background: var(--navy-deep); min-height: 100vh;
  display: flex; flex-direction: column;
  padding: 48px 72px; position: relative; overflow: hidden;
}
.hero-bg-glow {
  position: absolute; top: -300px; right: -200px; width: 800px; height: 800px;
  pointer-events: none;
  background: radial-gradient(circle, rgba(132,3,197,0.13) 0%, transparent 65%);
  animation: glow-pulse 6s ease-in-out infinite;
}
.hero-bg-glow2 {
  position: absolute; bottom: -300px; left: -100px; width: 600px; height: 600px;
  pointer-events: none;
  background: radial-gradient(circle, rgba(29,158,117,0.07) 0%, transparent 65%);
  animation: glow-pulse 8s ease-in-out infinite reverse;
}
@keyframes glow-pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}
.hero-shape {
  position: absolute; top: 0; right: 0; bottom: 0; width: 42%;
  background: rgba(255,255,255,0.015);
  clip-path: polygon(18% 0, 100% 0, 100% 100%, 0% 100%);
  pointer-events: none;
}
.hero-logo { z-index: 2; margin-bottom: 80px; animation: fade-down 0.7s ease forwards; }
.hero-logo img { height: 36px; width: auto; }
@keyframes fade-down { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: translateY(0); } }
.hero-main { z-index: 2; display: flex; align-items: center; justify-content: space-between; flex: 1; gap: 64px; }
.hero-text { flex: 0 0 44%; display: flex; flex-direction: column; gap: 0; }
.hero-eyebrow {
  font-size: 11px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--teal); margin-bottom: 28px;
  opacity: 0; animation: fade-up 0.7s 0.15s ease forwards;
}
.hero-title {
  font-size: clamp(36px, 4.2vw, 60px); font-weight: 300; line-height: 1.1;
  color: var(--white); letter-spacing: -2px; margin-bottom: 36px;
  opacity: 0; animation: fade-up 0.7s 0.28s ease forwards;
}
.hero-title strong { font-weight: 700; }
.hero-sub {
  font-size: 17px; color: rgba(255,255,255,0.42); line-height: 1.8;
  max-width: 400px; margin-bottom: 48px;
  opacity: 0; animation: fade-up 0.7s 0.42s ease forwards;
}
.hero-btns {
  display: flex; align-items: center; gap: 24px;
  opacity: 0; animation: fade-up 0.7s 0.56s ease forwards;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--purple); color: var(--white);
  padding: 14px 32px; border-radius: 100px;
  font-size: 15px; font-weight: 600; text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(132,3,197,0.4); }
.btn-ghost {
  color: rgba(255,255,255,0.38); font-size: 14px; font-weight: 500;
  text-decoration: none; transition: color 0.2s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-ghost:hover { color: var(--white); }
.hero-visual {
  flex: 0 0 52%;
  opacity: 0; animation: fade-up 0.9s 0.35s ease forwards;
}
.hero-visual img {
  width: 100%; border-radius: 16px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.35), 0 8px 24px rgba(0,0,0,0.15), 0 2px 8px rgba(0,0,0,0.1);
  transform: perspective(1400px) rotateY(-5deg) rotateX(2deg);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  border: none; outline: none;
  background: transparent;
}
.hero-visual img:hover {
  transform: perspective(1400px) rotateY(-2deg) rotateX(1deg);
  box-shadow: 0 32px 80px rgba(0,0,0,0.4), 0 8px 24px rgba(0,0,0,0.2);
}
@keyframes fade-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

/* SECTIONS */
section { padding: 100px 72px; }
.section-tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; font-weight: 600; letter-spacing: 2px;
  text-transform: uppercase; color: var(--purple); margin-bottom: 16px;
}
.section-tag::before { content: ''; width: 20px; height: 2px; background: var(--purple); flex-shrink: 0; }
.section-title { font-size: clamp(28px, 3.2vw, 46px); font-weight: 700; line-height: 1.1; color: var(--navy-deep); letter-spacing: -1.5px; margin-bottom: 14px; }
.section-sub { font-size: 17px; color: var(--grey-dark); line-height: 1.7; max-width: 540px; margin-bottom: 56px; }

/* SVG ICONS */
.icon { display: block; width: 24px; height: 24px; flex-shrink: 0; }

/* PROBLEM */
.problem { background: var(--navy-deep); }
.problem .section-tag { color: var(--teal); }
.problem .section-tag::before { background: var(--teal); }
.problem .section-title { color: var(--white); }
.problem .section-sub { color: rgba(255,255,255,0.38); }

.stat-banner {
  display: flex; align-items: stretch; gap: 0;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
  border-radius: 20px; overflow: hidden; margin-bottom: 64px;
}
.stat-item {
  flex: 1; padding: 48px 40px; text-align: center;
  border-right: 1px solid rgba(255,255,255,0.08);
  transition: background 0.3s;
}
.stat-item:last-child { border-right: none; }
.stat-item:hover { background: rgba(255,255,255,0.04); }
.stat-num {
  font-size: clamp(48px, 6.5vw, 84px); font-weight: 700;
  line-height: 1; letter-spacing: -4px; margin-bottom: 10px;
}
.stat-num.teal { color: var(--teal); }
.stat-num.purple { color: var(--purple-light); }
.stat-label { font-size: 12px; color: rgba(255,255,255,0.3); font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; }
.stat-desc { font-size: 15px; color: rgba(255,255,255,0.45); line-height: 1.6; margin-top: 6px; }

.problems-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  background: rgba(255,255,255,0.06); border-radius: 18px; overflow: hidden;
}
.problem-card {
  background: rgba(255,255,255,0.03); padding: 36px 32px;
  transition: background 0.2s, transform 0.2s; cursor: default;
}
.problem-card:hover { background: rgba(255,255,255,0.07); }
.problem-card-icon {
  width: 48px; height: 48px; border-radius: 12px;
  background: rgba(132,3,197,0.18); border: 1px solid rgba(132,3,197,0.22);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px; transition: transform 0.3s;
  color: rgba(255,255,255,0.7);
}
.problem-card:hover .problem-card-icon { transform: scale(1.08) rotate(-3deg); }
.problem-card-title { font-size: 17px; font-weight: 600; color: var(--white); margin-bottom: 10px; }
.problem-card-text { font-size: 14px; color: rgba(255,255,255,0.38); line-height: 1.7; }
.problem-solve { background: rgba(29,158,117,0.07) !important; }
.problem-solve .problem-card-icon { background: rgba(29,158,117,0.18); border-color: rgba(29,158,117,0.25); color: var(--teal); }
.problem-solve .problem-card-title { color: var(--teal); }

.users-row { margin-top: 56px; display: flex; align-items: center; flex-wrap: wrap; gap: 10px; }
.users-label { font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.22); margin-right: 6px; }
.user-pill {
  background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px; padding: 6px 16px; font-size: 13px; color: rgba(255,255,255,0.45);
  transition: background 0.2s, color 0.2s; cursor: default;
}
.user-pill:hover { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.75); }

/* PLATFORM */
.platform { background: var(--off-white); }
.platform-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
  background: var(--grey); border-radius: 20px; overflow: hidden; margin-bottom: 40px;
}
.platform-card {
  background: var(--white); padding: 32px 28px;
  transition: background 0.2s, transform 0.2s; cursor: default;
}
.platform-card:hover { background: #ECEBF8; transform: translateY(-2px); }
.platform-card-icon {
  width: 44px; height: 44px; border-radius: 10px;
  background: rgba(132,3,197,0.08); border: 1px solid rgba(132,3,197,0.12);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16px; transition: transform 0.3s;
  color: var(--purple);
}
.platform-card:hover .platform-card-icon { transform: scale(1.1); }
.platform-card-title { font-size: 15px; font-weight: 700; color: var(--navy-deep); margin-bottom: 8px; }
.platform-card-text { font-size: 13px; color: var(--grey-dark); line-height: 1.65; }

.integrations-row {
  display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-top: 40px;
}
.integrations-label { font-size: 12px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--grey-mid); margin-right: 4px; }
.integration-pill {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--white); border: 1px solid var(--grey);
  border-radius: 100px; padding: 8px 18px;
  font-size: 13px; font-weight: 500; color: var(--grey-dark);
  transition: border-color 0.2s, color 0.2s;
}
.integration-pill:hover { border-color: var(--purple); color: var(--purple); }
.integration-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* WHY */
.why { background: var(--white); }
.why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.why-card {
  background: var(--off-white); border: 1px solid var(--grey);
  border-radius: 18px; padding: 36px 32px;
  transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  cursor: default; position: relative; overflow: hidden;
}
.why-card::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--purple), var(--teal));
  transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease;
}
.why-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(36,36,80,0.09); border-color: rgba(132,3,197,0.18); }
.why-card:hover::after { transform: scaleX(1); }
.why-card-icon { width: 40px; height: 40px; margin-bottom: 20px; color: var(--purple); }
.why-card-title { font-size: 18px; font-weight: 700; color: var(--navy-deep); margin-bottom: 12px; line-height: 1.2; }
.why-card-text { font-size: 15px; color: var(--grey-dark); line-height: 1.7; }
.why-highlight { grid-column: 1 / -1; background: var(--navy-deep); border-color: transparent; }
.why-highlight::after { display: none; }
.why-highlight .why-card-title { color: var(--white); font-size: 22px; }
.why-highlight .why-card-text { color: rgba(255,255,255,0.42); }
.why-highlight:hover { border-color: transparent; box-shadow: none; transform: none; }

/* COMPARISON */
.comparison { background: var(--navy-deep); }
.comparison .section-tag { color: var(--teal); }
.comparison .section-tag::before { background: var(--teal); }
.comparison .section-title { color: var(--white); }
.comp-table { width: 100%; border-collapse: collapse; border-radius: 16px; overflow: hidden; }
.comp-table th {
  background: rgba(255,255,255,0.07); padding: 18px 20px;
  font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.45);
  text-align: center; letter-spacing: 0.3px;
}
.comp-table th:first-child { text-align: left; padding-left: 28px; }
.comp-table th.ew { background: rgba(132,3,197,0.28); color: var(--white); font-size: 13px; }
.comp-table td {
  padding: 13px 20px; font-size: 14px; color: rgba(255,255,255,0.5);
  border-bottom: 1px solid rgba(255,255,255,0.05); text-align: center;
  transition: background 0.15s;
}
.comp-table tr:hover td { background: rgba(255,255,255,0.03); }
.comp-table td:first-child { text-align: left; padding-left: 28px; color: rgba(255,255,255,0.72); font-weight: 500; }
.comp-table td.ew { background: rgba(132,3,197,0.08); }
.comp-table tr:hover td.ew { background: rgba(132,3,197,0.14); }
.comp-table tr:last-child td { border-bottom: none; }
.check { color: #1D9E75; font-size: 16px; font-weight: 700; }
.cross { color: rgba(255,255,255,0.18); font-size: 16px; }

/* TESTIMONIALS */
.testimonials { background: var(--off-white); }
.testimonials .section-tag { color: var(--purple); }
.testimonials .section-tag::before { background: var(--purple); }
.testimonials-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
}
.testimonial-card {
  background: var(--white); border: 1px solid var(--grey);
  border-radius: 18px; padding: 36px 32px;
  transition: transform 0.25s, box-shadow 0.25s;
  cursor: default; display: flex; flex-direction: column; gap: 20px;
}
.testimonial-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(36,36,80,0.09);
}
.testimonial-quote {
  font-size: 15px; color: var(--navy); line-height: 1.75;
  font-style: italic; flex: 1;
}
.testimonial-quote::before { content: '"'; color: var(--purple); font-size: 32px; line-height: 0; vertical-align: -12px; margin-right: 4px; font-style: normal; }
.testimonial-author {
  display: flex; align-items: center; gap: 14px;
  padding-top: 20px; border-top: 1px solid var(--grey);
}
.testimonial-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: linear-gradient(135deg, var(--purple), var(--blue));
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 700; color: var(--white); flex-shrink: 0;
}
.testimonial-name { font-size: 14px; font-weight: 600; color: var(--navy-deep); }
.testimonial-role { font-size: 13px; color: var(--grey-mid); }

/* PRICING CTA */
.pricing-cta { background: var(--off-white); padding: 80px 72px; }
.pricing-inner {
  background: var(--navy-deep); border-radius: 28px; padding: 80px 72px;
  position: relative; overflow: hidden; text-align: center;
}
.pricing-inner::before {
  content: ''; position: absolute; top: -200px; right: -200px;
  width: 600px; height: 600px; pointer-events: none;
  background: radial-gradient(circle, rgba(132,3,197,0.16) 0%, transparent 65%);
}
.pricing-inner::after {
  content: ''; position: absolute; bottom: -200px; left: -100px;
  width: 500px; height: 500px; pointer-events: none;
  background: radial-gradient(circle, rgba(29,158,117,0.08) 0%, transparent 65%);
}
.pricing-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: var(--teal); margin-bottom: 20px; position: relative; z-index: 1; }
.pricing-title { font-size: clamp(30px, 3.5vw, 50px); font-weight: 700; color: var(--white); letter-spacing: -2px; line-height: 1.06; margin-bottom: 14px; position: relative; z-index: 1; }
.pricing-sub { font-size: 17px; color: rgba(255,255,255,0.38); line-height: 1.7; max-width: 400px; margin: 0 auto 48px; position: relative; z-index: 1; }
.pricing-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--white); color: var(--navy-deep);
  padding: 16px 40px; border-radius: 100px;
  font-size: 16px; font-weight: 700; text-decoration: none;
  position: relative; z-index: 1;
  transition: transform 0.2s, box-shadow 0.2s;
}
.pricing-btn:hover { transform: translateY(-3px); box-shadow: 0 20px 60px rgba(0,0,0,0.45); }

/* STEPS */
.steps { background: var(--white); }
.steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.step-card {
  background: var(--off-white); border: 1px solid var(--grey);
  border-radius: 18px; padding: 32px 28px;
  position: relative; overflow: hidden;
  transition: transform 0.25s, box-shadow 0.25s;
}
.step-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(36,36,80,0.08); }
.step-top-bar { position: absolute; top: 0; left: 0; right: 0; height: 3px; }
.step-card:nth-child(1) .step-top-bar { background: var(--teal); }
.step-card:nth-child(2) .step-top-bar { background: var(--blue); }
.step-card:nth-child(3) .step-top-bar { background: var(--purple); }
.step-card:nth-child(4) .step-top-bar { background: linear-gradient(90deg, var(--purple), var(--teal)); }
.step-num {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--white); border: 1px solid var(--grey);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 20px;
}
.step-title { font-size: 20px; font-weight: 700; color: var(--navy-deep); margin-bottom: 12px; }
.step-text { font-size: 14px; color: var(--grey-dark); line-height: 1.7; }
.steps-cta { margin-top: 48px; text-align: center; }

/* FINAL CTA */
.final-cta {
  background: var(--navy-deep); text-align: center;
  padding: 120px 72px; position: relative; overflow: hidden;
}
.final-cta-bg {
  position: absolute; inset: 0; pointer-events: none;
  background: linear-gradient(135deg, rgba(132,3,197,0.1) 0%, transparent 50%, rgba(29,158,117,0.07) 100%);
  animation: cta-shift 8s ease-in-out infinite alternate;
}
@keyframes cta-shift { from { opacity: 0.5; } to { opacity: 1; } }
.final-cta-title { font-size: clamp(40px, 5.5vw, 72px); font-weight: 700; color: var(--white); letter-spacing: -3px; line-height: 1.04; margin-bottom: 16px; position: relative; z-index: 1; }
.final-cta-title span { color: var(--purple-light); }
.final-cta-sub { font-size: 17px; color: rgba(255,255,255,0.32); margin-bottom: 48px; position: relative; z-index: 1; }
.final-cta-btn {
  display: inline-flex; align-items: center; gap: 12px;
  border: 2px solid rgba(255,255,255,0.22); border-radius: 100px;
  padding: 18px 48px; font-size: 17px; font-weight: 600;
  color: var(--white); text-decoration: none;
  position: relative; z-index: 1;
  transition: border-color 0.2s, background 0.2s, transform 0.2s;
}
.final-cta-btn:hover { border-color: var(--white); background: rgba(255,255,255,0.08); transform: translateY(-2px); }

/* RESPONSIVE */
@media (max-width: 960px) {
  section, .hero, .pricing-cta, .final-cta { padding-left: 28px; padding-right: 28px; }
  .hero-main { flex-direction: column; }
  .hero-text, .hero-visual { flex: unset; width: 100%; }
  .hero-visual { margin-top: 40px; }
  .hero-visual img { transform: none; box-shadow: 0 24px 60px rgba(0,0,0,0.4); }
  .problems-grid, .why-grid, .testimonials-grid { grid-template-columns: 1fr; }
  .platform-grid { grid-template-columns: repeat(2, 1fr); }
  .steps-grid { grid-template-columns: repeat(2, 1fr); }
  .why-highlight { grid-column: 1; }
  .stat-banner { flex-direction: column; }
  .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .stat-item:last-child { border-bottom: none; }
  .pricing-inner { padding: 48px 32px; }
}
@media (max-width: 600px) {
  .steps-grid, .platform-grid { grid-template-columns: 1fr; }
}

/* FEATURE SHOWCASE */
.features { background: var(--navy-deep); }
.features .section-tag { color: var(--teal); }
.features .section-tag::before { background: var(--teal); }
.features .section-title { color: var(--white); }
.features .section-sub { color: rgba(255,255,255,0.38); margin-bottom: 0; }
.feature-block {
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
  align-items: center; padding: 64px 0;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.feature-block:last-child { border-bottom: none; }
.feature-block.reverse { direction: rtl; }
.feature-block.reverse > * { direction: ltr; }
.feature-text { }
.feature-label {
  font-size: 11px; font-weight: 600; letter-spacing: 2px;
  text-transform: uppercase; color: var(--teal); margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px;
}
